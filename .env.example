# Shared
NODE_ENV=development
TZ=UTC

# API
API_PORT=4000
PUBLIC_BASE_URL=http://localhost:4000
API_BASE_URL=http://localhost:4000
WEB_BASE_URL=http://localhost:5173
# IMPORTANT: in production, set this to a long (>=32 char) random string.
# Generate with:  openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret
UPLOAD_DIR=/app/uploads

# Production only: absolute path to the built React UI (apps/web/dist).
# When set, NestJS serves the UI at / and falls back to index.html for SPA routes.
# Leave unset for local dev (the web app runs via Vite separately).
# WEB_DIST_PATH=/opt/smm/web-dist

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/social_manager?schema=public

# Redis
REDIS_URL=redis://redis:6379

# Publishing mode: mock | real
PUBLISHING_MODE=mock
FIRST_ANALYTICS_DELAY_MS=60000
ANALYTICS_SYNC_INTERVAL_MS=300000

# Storage: local by default. MinIO/S3 remains optional for production swap.
STORAGE_DRIVER=local
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=social-media-assets
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Frontend
VITE_API_URL=http://localhost:4000/api

# Meta / Facebook / Instagram placeholders
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:4000/api/platforms/facebook/callback
INSTAGRAM_REDIRECT_URI=http://localhost:4000/api/platforms/instagram/callback

# X / Twitter placeholders
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=http://localhost:4000/api/platforms/twitter/callback

# TikTok placeholders
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:4000/api/platforms/tiktok/callback
